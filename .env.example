NAME=myproject
COMPOSE_PROJECT_NAME=$NAME

# Backend
BACKEND_MODE=fastapi
BACKEND_PORT=9812
CLASSIFIER_INTERVAL_SECONDS=5
VITE_BACKEND_URL=http://127.0.0.1:9812
BACKEND_STARTUP_SEED_MODE=always
BACKEND_STARTUP_SEED_NODE_COUNT=8
BACKEND_STARTUP_SEED_SEVERE_RATIO=0.1
BACKEND_STARTUP_SEED_MODERATE_RATIO=0.1
BACKEND_STARTUP_SEED_HISTORY_POINTS=120
BACKEND_STARTUP_SEED_INTERVAL_MINUTES=5
BACKEND_STARTUP_SEED_RANDOM_SEED=42

# Ports
REDIS_PORT=6378
GRAFANA_PORT=3125
LOKI_PORT=3142

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# MongoDB
MONGO_PORT=27017
MONGO_DB=app
MONGO_USER=admin
MONGO_PASSWORD=admin123
MONGO_HOST=localhost

DATABASE_TYPE=postgres

# Redis
REDIS_URL=redis://localhost:$REDIS_PORT

# Logging
LOGDIR="/tmp/logs-$NAME/"

# Supabase (webapp auth - set VITE_REQUIRE_AUTH=true to enable gating)
VITE_REQUIRE_AUTH=false
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost:9900

# ML
# URL for ML inference API (prod should point to deployed inference server)
ML_URL=http://localhost:8200
ML_TIMEOUT_SECONDS=3
# Optional: defaults to models/weights relative to inference.py
ML_LATEST_WEIGHTS_PATH=/app/ml/models/weights
# Optional: specify exact model file to load
ML_MODEL_FILE=/app/ml/models/weights/synthetic_benchmark/xgboost_multiclass.pkl
MLFLOW_TRACKING_URI=http://localhost:5000

# Node Simulator (docker compose --profile sim)
SIM_NODE_ID=BEL-VLV-003
SIM_PROFILE=gear_stuck
SIM_SPEED=1.0
SIM_LOOP=1

# AI / Agents
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AGENT_MODEL=gpt-5.4
AGENT_MAX_TOOL_STEPS=6
ESCALATION_PHONE_NUMBER=+34672359401
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_WEBHOOK_SECRET=whsec_...
# Optional: use Bedrock instead of direct Anthropic API
# CLAUDE_CODE_USE_BEDROCK=1
# Optional: use Vertex AI
# CLAUDE_CODE_USE_VERTEX=1
