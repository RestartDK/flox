{
  "name": "On-Site Engineer Escalation",
  "conversation_config": {
    "asr": {
      "quality": "high",
      "provider": "elevenlabs",
      "user_input_audio_format": "ulaw_8000",
      "keywords": []
    },
    "turn": {
      "turn_timeout": 7,
      "silence_end_call_timeout": 20,
      "turn_eagerness": "normal",
      "mode": "turn"
    },
    "tts": {
      "model_id": "eleven_flash_v2",
      "voice_id": "EXAVITQu4vr4xnSDxMaL",
      "supported_voices": [],
      "agent_output_audio_format": "ulaw_8000",
      "optimize_streaming_latency": 3,
      "stability": 0.5,
      "speed": 1,
      "similarity_boost": 0.8,
      "pronunciation_dictionary_locators": []
    },
    "conversation": {
      "text_only": false,
      "max_duration_seconds": 600,
      "client_events": [
        "audio",
        "interruption"
      ]
    },
    "language_presets": {},
    "agent": {
      "first_message": "Hello, this is the automated building operations assistant for {{building_name}} calling about {{product_name}}. I need to brief you on the current situation, the failure, and the likely cause.",
      "language": "en",
      "disable_first_message_interruptions": true,
      "dynamic_variables": {
        "dynamic_variable_placeholders": {
          "building_name": "",
          "engineer_name": "",
          "product_name": "",
          "situation_summary": "",
          "failure_name": "",
          "likely_cause": "",
          "likely_cause_confidence": "",
          "fault_id": "",
          "device_id": "",
          "device_name": "",
          "severity": "",
          "failure_summary": "",
          "recommended_action": "",
          "detected_at": "",
          "estimated_impact": "",
          "energy_waste": "",
          "triggered_by": ""
        }
      },
        "prompt": {
          "prompt": "You are the automated building operations escalation assistant for {{building_name}}.\n\nYour job is to call the on-site engineer and communicate one active issue using only the variables supplied to you.\n\nYou must brief the engineer in this exact order:\n1. Product: identify the affected product as {{product_name}}.\n2. Situation: explain the current operational situation as {{situation_summary}}.\n3. Failure: explain the detected failure as {{failure_name}} and, when useful, add {{failure_summary}}.\n4. Likely cause: explain the likely cause as {{likely_cause}}.\n\nAdditional instructions:\n- State that the affected device is {{device_name}} ({{device_id}}).\n- State the severity as {{severity}} and the detection time as {{detected_at}}.\n- State the recommended action as {{recommended_action}}.\n- Treat the likely cause as provisional, not certain.\n- If {{likely_cause_confidence}} is available, reflect that briefly using plain language.\n- Ask the engineer to acknowledge receipt of the issue.\n- Ask for a callback ETA or intervention timing if they can provide one.\n- Keep answers short, operational, and factual.\n\nRules:\n- Never invent telemetry, root cause, cost, safety claims, or remediation steps beyond the supplied variables.\n- If likely cause is missing or blank, say the likely cause is still under investigation.\n- If asked for unsupported details, say the operations team will follow up with additional information.\n- Do not roleplay, chat casually, or discuss unrelated topics.\n- End the call once the engineer acknowledges the issue or it is clear they are unavailable to help right now.",
        "llm": "gpt-5-mini",
        "temperature": 0,
        "max_tokens": 220,
        "tool_ids": [],
        "mcp_server_ids": [],
        "native_mcp_server_ids": [],
        "knowledge_base": [],
        "ignore_default_personality": false,
        "rag": {
          "enabled": false,
          "embedding_model": "e5_mistral_7b_instruct",
          "max_vector_distance": 0.6,
          "max_documents_length": 50000,
          "max_retrieved_rag_chunks_count": 20
        },
        "custom_llm": null
      }
    }
  },
